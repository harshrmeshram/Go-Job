# Root environment variables for local development
# Copy this file to .env before running the monorepo locally.

# Application mode: development, test, or production.
APP_ENV=development

# Base URLs used by the web app and extension.
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Web app environment variables.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_EXTENSION_ID=alvest-extension

# Extension environment variables.
VITE_API_BASE_URL=http://localhost:8000
VITE_EXTENSION_ENV=development

# Backend database configuration.
# Required now for local development and Docker-based database setup.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/alvest

# Redis configuration.
# Required now for future queues and caching. Safe to leave as a default for local setup.
REDIS_URL=redis://localhost:6379/0

# JWT secrets.
# Required now for auth-related scaffolding, even though auth features are not implemented yet.
JWT_SECRET=change-me-in-local-dev-only
JWT_REFRESH_SECRET=change-me-in-local-dev-only

# AI provider configuration.
# Placeholder for future AI features.
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o-mini

# File storage configuration.
# Placeholder for future resume upload and document storage.
STORAGE_ENDPOINT=https://example.storage.provider.com
STORAGE_ACCESS_KEY=replace-me
STORAGE_SECRET_KEY=replace-me
STORAGE_BUCKET=alvest-dev
STORAGE_PUBLIC_URL=https://example.storage.provider.com/alvest-dev

# Email transport configuration.
# Placeholder for future verification and notification flows.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# Optional observability configuration.
# Placeholder for future monitoring and tracing.
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
